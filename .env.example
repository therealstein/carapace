# Domain for Caddy TLS (set to your domain for auto HTTPS)
DOMAIN=localhost

# --- Multi-route config (recommended) ---
# Each route: ROUTE_<NAME>_TOKEN, ROUTE_<NAME>_UPSTREAM, ROUTE_<NAME>_HOOKS_TOKEN
# Carapace routes requests to the correct upstream based on which token matches.

ROUTE_PRIMARY_TOKEN=
ROUTE_PRIMARY_UPSTREAM=http://openclaw-primary:18789
ROUTE_PRIMARY_HOOKS_TOKEN=

ROUTE_SECONDARY_TOKEN=
ROUTE_SECONDARY_UPSTREAM=http://openclaw-secondary:18789
ROUTE_SECONDARY_HOOKS_TOKEN=

# Gateway tokens (for OpenClaw healthchecks)
OPENCLAW_PRIMARY_GATEWAY_TOKEN=
OPENCLAW_SECONDARY_GATEWAY_TOKEN=

# --- OR legacy single-route config (backward compatible) ---
# CARAPACE_TOKEN=
# OPENCLAW_UPSTREAM=http://openclaw:18789
# OPENCLAW_HOOKS_TOKEN=
# OPENCLAW_GATEWAY_TOKEN=

# --- Global (optional) ---
CARAPACE_HMAC_SECRET=
